rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /earnings/{earningId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /companies/{companyId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /earnings_q1_2026/{earningId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /trading_history_q1_2026/{pointId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /trading_history_q2_2026/{pointId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
